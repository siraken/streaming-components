---
export const prerender = true;

import Layout from '../../layouts/Base.astro';
import { ChannelControl } from '../../components/control/channel-control';
import '../../styles/globals.css';
---

<Layout title="Just Chatting Control">
  <ChannelControl
    client:only="react"
    channel="just-chatting"
    accent="#6366f1"
    screenPath="/screens/just-chatting/"
    fields={[
      { key: 'name', label: '表示名', placeholder: '名前を入力' },
      { key: 'title', label: '配信タイトル', placeholder: 'タイトルを入力' },
      { key: 'social', label: 'SNS', placeholder: '@handle' },
    ]}
  />
</Layout>
