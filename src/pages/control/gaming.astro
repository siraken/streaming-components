---
export const prerender = true;

import Layout from '../../layouts/Base.astro';
import { ChannelControl } from '../../components/control/channel-control';
import '../../styles/globals.css';
---

<Layout title="Gaming Control">
  <ChannelControl
    client:only="react"
    channel="gaming"
    accent="#22d3ee"
    screenPath="/screens/gaming/"
    fields={[
      { key: 'game', label: 'ゲームタイトル', placeholder: 'ゲーム名を入力' },
      { key: 'name', label: '表示名', placeholder: '名前を入力' },
    ]}
  />
</Layout>
