---
export const prerender = true;

import Layout from '../../layouts/Base.astro';
import '../../styles/globals.css';

const icons: Record<string, string> = {
  countdown: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="9"/><polyline points="12 9 12 13 15 16"/><line x1="12" y1="1" x2="12" y2="4"/><line x1="9" y1="2" x2="15" y2="2"/></svg>',
  pause: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="10" y1="15" x2="10" y2="9"/><line x1="14" y1="15" x2="14" y2="9"/></svg>',
  heart: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>',
  chat: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
  users: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  gamepad: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="11" x2="10" y2="11"/><line x1="8" y1="9" x2="8" y2="13"/><line x1="15" y1="12" x2="15.01" y2="12"/><line x1="18" y1="10" x2="18.01" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.544-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/></svg>',
  music: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>',
};

const items = [
  { name: 'Starting Soon', url: '/screens/starting-soon/', description: '配信開始前の待機画面。カウントダウン付き。', icon: 'countdown', tag: 'Standby' },
  { name: 'Be Right Back', url: '/screens/brb/', description: '離席中・休憩画面。', icon: 'pause', tag: 'Standby' },
  { name: 'Ending', url: '/screens/ending/', description: '配信終了画面。SNSリンク表示対応。', icon: 'heart', tag: 'Standby' },
  { name: 'Just Chatting', url: '/screens/just-chatting/', description: '雑談配信用レイアウト。カメラ枠+情報バー。', icon: 'chat', tag: 'Layout' },
  { name: 'Zatsudan', url: '/screens/zatsudan/', description: 'VTuber風雑談レイアウト。装飾フレーム+チャット+トピック。', icon: 'users', tag: 'Layout' },
  { name: 'Gaming', url: '/screens/gaming/', description: 'ゲーム配信用。ゲーム画面+VTuberワイプ+情報バー。', icon: 'gamepad', tag: 'Layout' },
  { name: 'Karaoke', url: '/screens/karaoke/', description: '歌枠用。曲名表示+ビジュアライザー+リクエスト欄。', icon: 'music', tag: 'Layout' },
];
---

<Layout title="Screens — Streaming Components">
  <div class="pg-root">
    <header class="pg-header">
      <a href="/" class="pg-back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
      </a>
      <div>
        <h1 class="pg-title">Screens</h1>
        <p class="pg-sub">1920×1080 配信画面レイアウト</p>
      </div>
    </header>

    <main class="pg-main">
      <div class="pg-grid">
        {items.map((item) => (
          <a href={item.url} class="pg-card">
            <div class="pg-card-top">
              <div class="pg-card-icon">
                <Fragment set:html={icons[item.icon]} />
              </div>
              <span class="pg-card-tag">{item.tag}</span>
            </div>
            <h3 class="pg-card-name">{item.name}</h3>
            <p class="pg-card-desc">{item.description}</p>
            <div class="pg-card-badge">1920×1080</div>
          </a>
        ))}
      </div>
    </main>
  </div>
</Layout>

<style>
  .pg-root {
    min-height: 100vh;
    background-color: #1e1e2e;
    background-image:
      radial-gradient(ellipse at 20% 0%, rgba(139, 92, 246, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 100%, rgba(99, 102, 241, 0.04) 0%, transparent 60%);
    font-family: var(--font-inter), -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: #cdd6f4;
    -webkit-font-smoothing: antialiased;
  }

  .pg-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 24px 32px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .pg-back {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
    flex-shrink: 0;
  }

  .pg-back:hover {
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.8);
  }

  .pg-title {
    font-size: 1rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.9);
  }

  .pg-sub {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
    margin-top: 2px;
  }

  .pg-main {
    max-width: 900px;
    margin: 0 auto;
    padding: 32px 24px 64px;
  }

  .pg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .pg-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s, border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .pg-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(139, 92, 246, 0.25);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(139, 92, 246, 0.1);
    transform: translateY(-2px);
  }

  .pg-card:hover .pg-card-icon {
    background: rgba(139, 92, 246, 0.15);
    color: #a78bfa;
  }

  .pg-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .pg-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.4);
    transition: background 0.2s, color 0.2s;
  }

  .pg-card-tag {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.2);
    padding: 3px 8px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.03);
  }

  .pg-card-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 6px;
  }

  .pg-card-desc {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
    line-height: 1.5;
    flex: 1;
  }

  .pg-card-badge {
    display: inline-block;
    margin-top: 14px;
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.65rem;
    font-weight: 500;
    color: rgba(139, 92, 246, 0.5);
    padding: 3px 8px;
    border-radius: 6px;
    background: rgba(139, 92, 246, 0.06);
    border: 1px solid rgba(139, 92, 246, 0.1);
    width: fit-content;
  }
</style>
