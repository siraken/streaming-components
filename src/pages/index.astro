---
export const prerender = true;

import Layout from '../layouts/Base.astro';
import '../styles/globals.css';

const icons: Record<string, string> = {
  clock: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  counter: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="12" y1="6" x2="12" y2="14"/></svg>',
  mic: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>',
  'lower-third': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="14" width="20" height="7" rx="2"/><line x1="6" y1="17" x2="14" y2="17"/></svg>',
  visualizer: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="20" x2="4" y2="14"/><line x1="8" y1="20" x2="8" y2="8"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="16" y1="20" x2="16" y2="10"/><line x1="20" y1="20" x2="20" y2="16"/></svg>',
  particles: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="10" cy="18" r="2"/><circle cx="20" cy="18" r="1.5"/><line x1="7.5" y1="7.5" x2="9" y2="16.5"/><line x1="16.5" y1="9.5" x2="11" y2="16.5"/><line x1="18.5" y1="16.5" x2="11.5" y2="18"/></svg>',
  countdown: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="9"/><polyline points="12 9 12 13 15 16"/><line x1="12" y1="1" x2="12" y2="4"/><line x1="9" y1="2" x2="15" y2="2"/></svg>',
  alert: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>',
};

const tools = [
  {
    name: 'Clock',
    url: '/clock/',
    description: '現在時刻をリアルタイム表示。タイムゾーン調整対応。',
    icon: 'clock',
    category: 'info',
  },
  {
    name: 'Counter',
    url: '/counter/',
    description: '汎用カウンター。スコアや回数の表示に。',
    icon: 'counter',
    category: 'info',
  },
  {
    name: 'Speech Recognition',
    url: '/speech-recognition/',
    description: 'Web Speech APIによるリアルタイム自動字幕。',
    icon: 'mic',
    category: 'info',
  },
  {
    name: 'Lower Third',
    url: '/lower-third/',
    description: 'アニメーション付き名前・肩書きバナー。',
    icon: 'lower-third',
    category: 'overlay',
  },
  {
    name: 'Visualizer',
    url: '/visualizer/',
    description: 'オーディオスペクトラム風のアニメーション。',
    icon: 'visualizer',
    category: 'overlay',
  },
  {
    name: 'Particles',
    url: '/particles/',
    description: 'パーティクルネットワーク背景エフェクト。',
    icon: 'particles',
    category: 'overlay',
  },
  {
    name: 'Countdown',
    url: '/countdown/',
    description: '配信開始前・休憩・終了用カウントダウン。',
    icon: 'countdown',
    category: 'screen',
  },
  {
    name: 'Alert Box',
    url: '/alert-box/?demo=true',
    description: '通知ポップアップ。フォロー・サブスク等。',
    icon: 'alert',
    category: 'overlay',
  },
];

const categories = [
  { key: 'info', label: 'Information' },
  { key: 'overlay', label: 'Overlays' },
  { key: 'screen', label: 'Screens' },
];
---

<Layout title="Streaming Components">
  <div class="sc-root">
    <header class="sc-header">
      <div class="sc-logo">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10" />
          <polygon points="10 8 16 12 10 16 10 8" />
        </svg>
        <span>Streaming Components</span>
      </div>
    </header>

    <main class="sc-main">
      {categories.map((cat) => {
        const items = tools.filter((t) => t.category === cat.key);
        if (items.length === 0) return null;
        return (
          <section class="sc-section">
            <h2 class="sc-section-title">{cat.label}</h2>
            <div class="sc-grid">
              {items.map((tool) => (
                <a href={tool.url} class="sc-card">
                  <div class="sc-card-icon">
                    <Fragment set:html={icons[tool.icon]} />
                  </div>
                  <div class="sc-card-body">
                    <h3 class="sc-card-name">{tool.name}</h3>
                    <p class="sc-card-desc">{tool.description}</p>
                  </div>
                  <div class="sc-card-arrow">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="9 18 15 12 9 6" />
                    </svg>
                  </div>
                </a>
              ))}
            </div>
          </section>
        );
      })}
    </main>
  </div>
</Layout>

<style>
  .sc-root {
    min-height: 100vh;
    background-color: #1e1e2e;
    background-image:
      radial-gradient(ellipse at 20% 0%, rgba(99, 102, 241, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 100%, rgba(139, 92, 246, 0.04) 0%, transparent 60%);
    font-family: var(--font-inter), -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: #cdd6f4;
    -webkit-font-smoothing: antialiased;
  }

  .sc-header {
    padding: 20px 32px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .sc-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.01em;
  }

  .sc-logo svg {
    color: #6366f1;
  }

  .sc-main {
    max-width: 720px;
    margin: 0 auto;
    padding: 32px 24px 64px;
  }

  .sc-section {
    margin-bottom: 32px;
  }

  .sc-section-title {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 10px;
    padding-left: 4px;
  }

  .sc-grid {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sc-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .sc-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(99, 102, 241, 0.25);
    box-shadow:
      0 0 0 1px rgba(99, 102, 241, 0.1),
      0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .sc-card:hover .sc-card-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .sc-card:hover .sc-card-icon {
    background: rgba(99, 102, 241, 0.15);
    color: #818cf8;
  }

  .sc-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.45);
    flex-shrink: 0;
    transition:
      background 0.2s ease,
      color 0.2s ease;
  }

  .sc-card-body {
    flex: 1;
    min-width: 0;
  }

  .sc-card-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.3;
  }

  .sc-card-desc {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    margin-top: 1px;
    line-height: 1.4;
  }

  .sc-card-arrow {
    color: rgba(255, 255, 255, 0.25);
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
    flex-shrink: 0;
  }
</style>
