---
export const prerender = true;

import Layout from '../layouts/Base.astro';
import '../styles/globals.css';

const sections = [
  {
    name: 'Overlays',
    url: '/overlays/',
    description: 'OBSブラウザソースとして個別に配置するオーバーレイ。時計・字幕・カウンター・エフェクト等。',
    count: 8,
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><rect x="7" y="7" width="10" height="10" rx="1" opacity="0.5"/></svg>',
    accent: '#6366f1',
  },
  {
    name: 'Screens',
    url: '/screens/',
    description: '1920×1080の配信画面レイアウト。待機画面・雑談・ゲーム・歌枠等。OBSでそのまま使用可能。',
    count: 7,
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
    accent: '#8b5cf6',
  },
];
---

<Layout title="Streaming Components">
  <div class="sc-root">
    <header class="sc-header">
      <div class="sc-logo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10" />
          <polygon points="10 8 16 12 10 16 10 8" />
        </svg>
        <span>Streaming Components</span>
      </div>
      <p class="sc-sub">OBS配信用オーバーレイ & スクリーンレイアウト</p>
    </header>

    <main class="sc-main">
      <div class="sc-grid">
        {sections.map((sec) => (
          <a href={sec.url} class="sc-card" style={`--accent: ${sec.accent}`}>
            <div class="sc-card-icon">
              <Fragment set:html={sec.icon} />
            </div>
            <h2 class="sc-card-name">{sec.name}</h2>
            <p class="sc-card-desc">{sec.description}</p>
            <div class="sc-card-footer">
              <span class="sc-card-count">{sec.count} items</span>
              <svg class="sc-card-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </main>
  </div>
</Layout>

<style>
  .sc-root {
    min-height: 100vh;
    background-color: #1e1e2e;
    background-image:
      radial-gradient(ellipse at 20% 0%, rgba(99, 102, 241, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 100%, rgba(139, 92, 246, 0.04) 0%, transparent 60%);
    font-family: var(--font-inter), -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: #cdd6f4;
    -webkit-font-smoothing: antialiased;
  }

  .sc-header {
    padding: 40px 32px 0;
    text-align: center;
  }

  .sc-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 1rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.01em;
  }

  .sc-logo svg {
    color: #6366f1;
  }

  .sc-sub {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.3);
    margin-top: 8px;
  }

  .sc-main {
    max-width: 720px;
    margin: 0 auto;
    padding: 48px 24px 64px;
  }

  .sc-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .sc-card {
    display: flex;
    flex-direction: column;
    padding: 32px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s, border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .sc-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2), 0 0 0 1px color-mix(in srgb, var(--accent) 15%, transparent);
    transform: translateY(-2px);
  }

  .sc-card:hover .sc-card-icon {
    background: color-mix(in srgb, var(--accent) 15%, transparent);
    color: var(--accent);
  }

  .sc-card:hover .sc-card-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .sc-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 20px;
    transition: background 0.2s, color 0.2s;
  }

  .sc-card-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 8px;
  }

  .sc-card-desc {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.35);
    line-height: 1.6;
    flex: 1;
  }

  .sc-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .sc-card-count {
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.25);
  }

  .sc-card-arrow {
    color: rgba(255, 255, 255, 0.25);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s, transform 0.2s;
  }
</style>
